							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code should be 403 or 401\", function () {",
									"    var code = pm.response.code;",
									"    pm.expect(code === 401 || code === 403).to.be.true;",
									"});",
									"",
									"pm.test(\"Explains that token has been revoked or is missing\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql(\"fail\");",
									"    pm.expect(jsonData.message).to.contain(\"again\");",
									"});"
